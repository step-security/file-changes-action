{
  "name": "file-changes-action",
  "version": "1.2.4",
  "engines": {
    "node": "24.x"
  },
  "description": "Creates outputs variables of files modified, added, or removed by a PR or Push.",
  "main": "lib/main.js",
  "scripts": {
    "build": "yarn && tsc",
    "build-package": "yarn && tsc -p tsconfig.build.json && ncc build lib/main.js -o dist",
    "test": "jest",
    "test-coverage": "jest --coverage",
    "test-integration": "jest -c jest.config.integration.js && rm -rf src/tests/outputs",
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "lint": "eslint --ext .ts ./",
    "clean": "rm -rf node_modules lib"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/step-security/file-changes-action.git"
  },
  "keywords": [
    "actions",
    "action",
    "github-action",
    "github-actions",
    "github",
    "node",
    "typescript",
    "examples"
  ],
  "author": "step-security",
  "homepage": "https://github.com/step-security/file-changes-action#README",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.2.3",
    "@actions/github": "^2.1.1",
    "axios": "^1.16.1"
  },
  "devDependencies": {
    "@octokit/types": "^2.5.0",
    "@types/jest": "^29.0.0",
    "@typescript-eslint/eslint-plugin": "^2.24.0",
    "@typescript-eslint/parser": "^2.24.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^6.8.0",
    "eslint-config-airbnb-typescript": "^7.0.0",
    "eslint-config-prettier": "^6.10.0",
    "eslint-import-resolver-typescript": "^2.0.0",
    "eslint-plugin-eslint-comments": "^3.1.2",
    "eslint-plugin-import": "^2.20.1",
    "eslint-plugin-jest": "^23.8.2",
    "eslint-plugin-jsx-a11y": "^6.2.3",
    "eslint-plugin-promise": "^4.2.1",
    "eslint-plugin-react": "^7.19.0",
    "eslint-plugin-react-hooks": "^2.5.0",
    "eslint-plugin-unicorn": "^17.2.0",
    "jest": "^29.0.0",
    "prettier": "^1.19.1",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
