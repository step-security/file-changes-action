{
  "name": "file-changes-action",
  "version": "1.2.4",
  "engines": {
    "node": "24.x"
  },
  "description": "Creates outputs variables of files modified, added, or removed by a PR or Push.",
  "main": "lib/main.js",
  "scripts": {
    "build": "yarn && tsc",
    "build-package": "yarn && tsc -p tsconfig.build.json && ncc build lib/main.js -o dist",
    "test": "jest",
    "test-coverage": "jest --coverage",
    "test-integration": "jest -c jest.config.integration.js && rm -rf src/tests/outputs",
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "lint": "eslint ./",
    "clean": "rm -rf node_modules lib"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/step-security/file-changes-action.git"
  },
  "keywords": [
    "actions",
    "action",
    "github-action",
    "github-actions",
    "github",
    "node",
    "typescript",
    "examples"
  ],
  "author": "step-security",
  "homepage": "https://github.com/step-security/file-changes-action#README",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^2.0.1",
    "@actions/github": "^9.1.1",
    "axios": "^1.16.0"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^9.39.4",
    "@octokit/types": "^2.5.0",
    "@types/jest": "^29.0.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "jest": "^29.0.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.59.3"
  }
}
